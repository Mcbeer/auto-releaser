{
  "name": "@mcbeer/auto-releaser",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "dep-aware-release": "./src/cli.ts"
  },
  "scripts": {
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude='**/.cache/**' --test-coverage-exclude='**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0"
  },
  "packageManager": "pnpm@11.9.0"
}
